# Close dialog is annoying, especially with cmd+z existing.
confirm-close-surface = false
link-previews = true

theme = "Catppuccin Mocha"
palette-generate = true
palette-harmonious = true

# Unset any default fonts before declaring our own
font-family =
font-family = "Berkeley Mono"
font-style-bold = "SemiBold"
font-style-italic = "SemiLight Oblique"
font-style-bold-italic = "SemiBold Oblique"
font-size = 13
bold-is-bright = true

# Berkeley-specific config
font-feature = calt
font-feature = liga
font-feature = ccmp
font-feature = locl
font-feature = ss08

clipboard-read = "allow"
copy-on-select = clipboard
clipboard-paste-protection = false
cursor-style = block
cursor-style-blink = true

background-opacity = 0.90
background-blur-radius  = 10
unfocused-split-opacity = 0.8
unfocused-split-fill = 101010
split-divider-color = aa2299
focus-follows-mouse = true
auto-update = check

# Uncomment to get updates from master
# auto-update-channel = tip

# Prevent spewing control sequences when accidentally hitting ENTER while CTRL is still
# held
keybind = ctrl+enter=text:\r

# Dvorak: work around physical vs. logical placement (https://github.com/ghostty-org/ghostty/discussions/7540)
keybind = cmd+equal=unbind
keybind = cmd+bracket_left=unbind
keybind = cmd+bracket_right=unbind
keybind = cmd+[=goto_split:previous
keybind = cmd+]=goto_split:next
keybind = cmd+==increase_font_size:1
keybind = cmd+-=decrease_font_size:1

# cmd+l => custom escape sequence
keybind = cmd+l=esc:sclear

keybind = global:ctrl+backquote=toggle_quick_terminal
quick-terminal-position = right
quick-terminal-size = 42%,96%
quick-terminal-autohide = true
keybind = cmd+k=toggle_command_palette

macos-option-as-alt = true
# Looks better when using Aerospace
macos-titlebar-style = hidden
macos-window-shadow = false

# Exclude ':' from selection boundary so that I can quickly select files with
# linenumbers (path/to/file:123)
selection-word-chars = " '\"│`|;,()[]{}<>$"
